<!-- admin.html -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Game Admin Panel</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      padding: 20px;
    }
    .panel {
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      max-width: 500px;
      margin: auto;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }
    .panel h2 {
      margin-top: 0;
    }
    .preview {
      margin-top: 20px;
      height: 200px;
      border: 1px solid #ccc;
      background-size: cover;
      background-position: center;
    }
  </style>
</head>
<body>
  <div class="panel">
    <h2>Game Settings</h2>
    <form id="settingsForm">
      <label for="menuBackground">Menu Background URL:</label><br>
      <input type="text" id="menuBackground" name="menuBackground" placeholder="Enter image URL"><br><br>

      <label for="titleColor">Game Title Color:</label><br>
      <input type="color" id="titleColor" name="titleColor" value="#000000"><br><br>

      <button type="button" onclick="applySettings()">Apply Settings</button>
    </form>

    <div class="preview" id="preview">Preview Area</div>
  </div>

  <script>
    function applySettings() {
      const bgUrl = document.getElementById('menuBackground').value;
      const titleColor = document.getElementById('titleColor').value;

      // Update preview
      const preview = document.getElementById('preview');
      if(bgUrl) preview.style.backgroundImage = `url('${bgUrl}')`;

      // Save settings to localStorage (optional)
      localStorage.setItem('menuBackground', bgUrl);
      localStorage.setItem('titleColor', titleColor);

